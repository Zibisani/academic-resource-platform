# Django
DJANGO_SECRET_KEY=your-secret-key-here-generate-a-new-one
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend

# Database
MYSQL_DATABASE=academichub
MYSQL_USER=academichub_user
MYSQL_PASSWORD=choose-a-strong-password
MYSQL_ROOT_PASSWORD=choose-a-strong-root-password
MYSQL_HOST=db
MYSQL_PORT=3306

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173

# JWT
JWT_SIGNING_KEY=your-jwt-signing-key-here-make-it-long-and-random

# Email (password reset — use any SMTP, or leave blank to print to console)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=AcademicHub <your-email@gmail.com>

# File uploads
MAX_UPLOAD_SIZE_MB=50
